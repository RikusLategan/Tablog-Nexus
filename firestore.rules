rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidItem(data) {
      return data.keys().hasAll(['category', 'quantity', 'createdAt', 'userId']) &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.quantity is number &&
             data.userId == request.auth.uid &&
             (data.get('unit', '') is string && data.get('unit', '').size() <= 50) &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 2000) &&
             (data.get('tags', []) is list) &&
             (data.get('price', 0) is number) &&
             (data.get('name', '') is string && data.get('name', '').size() <= 200) &&
             (data.get('taskStatus', '') is string && data.get('taskStatus', '').size() <= 10) &&
             (data.get('loggedAt', request.time) is timestamp) &&
             (data.get('createdAt', request.time) is timestamp) &&
             (data.get('updatedAt', request.time) is timestamp);
    }

    match /items/{itemId} {
      // Rule 3: Path Variable Hardening
      // Rule 8: Secure List Queries
      allow get: if isOwner(existing().userId) && isValidId(itemId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Rule 10: Temporal Integrity
      // Relaxed createdAt for restoration (Undo)
      allow create: if isSignedIn() && 
                    isValidId(itemId) && 
                    isValidItem(incoming()) &&
                    (incoming().createdAt == request.time || incoming().createdAt is timestamp);
      
      allow update: if isOwner(existing().userId) && 
                    isValidId(itemId) && 
                    isValidItem(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;

      allow delete: if isOwner(existing().userId) && isValidId(itemId);
    }
  }
}
