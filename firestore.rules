rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidItem(data) {
      return data.keys().hasAll(['category', 'quantity', 'createdAt']) &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.quantity is number &&
             (data.get('unit', '') is string && data.get('unit', '').size() <= 50) &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 2000) &&
             (data.get('tags', []) is list) &&
             (data.get('price', 0) is number) &&
             (data.get('name', '') is string && data.get('name', '').size() <= 200) &&
             (data.get('updatedAt', request.time) is timestamp);
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                    isValidItem(request.resource.data) &&
                    request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && 
                    isValidItem(request.resource.data) &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    (request.resource.data.get('updatedAt', request.time) == request.time);
      allow delete: if isSignedIn();
    }
  }
}
